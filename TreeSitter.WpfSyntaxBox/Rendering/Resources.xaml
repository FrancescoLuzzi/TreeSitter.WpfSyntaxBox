<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:TreeSitter.WpfSyntaxBox">
    <Brush x:Key="TreeSitter.SyntaxBox.Border.MouseOver">#FF7EB4EA</Brush>
    <Brush x:Key="TreeSitter.SyntaxBox.Border.KeyboardFocused">#FF569DE5</Brush>

    <ControlTemplate x:Key="SyntaxTextBoxTemplate" TargetType="TextBox">
        <Border x:Name="border"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                Background="{TemplateBinding Background}"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Canvas x:Name="PART_LineNumbers"
                        Grid.Column="0"
                        Width="32"
                        Background="{TemplateBinding local:SyntaxBox.LineNumbersBackground}" />
                <Grid Grid.Column="1">
                    <Grid Margin="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                        <local:SyntaxRenderer x:Name="PART_SyntaxRenderer"
                                              Target="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                              IsHitTestVisible="False"
                                              TextOptions.TextRenderingMode="ClearType"
                                              TextOptions.TextFormattingMode="Display"
                                              DefaultForeground="{TemplateBinding local:SyntaxBox.OriginalForeground}"
                                              LineNumbersForeground="{TemplateBinding local:SyntaxBox.LineNumbersForeground}" />
                    </Grid>
                    <ScrollViewer x:Name="PART_ContentHost" Focusable="False" />
                </Grid>
            </Grid>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" TargetName="border" Value="0.56" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" TargetName="border" Value="{DynamicResource TreeSitter.SyntaxBox.Border.MouseOver}" />
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter Property="BorderBrush" TargetName="border" Value="{DynamicResource TreeSitter.SyntaxBox.Border.KeyboardFocused}" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>
</ResourceDictionary>
